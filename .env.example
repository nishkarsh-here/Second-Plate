# Root env reference for docker-compose. The compose file already sets sensible
# defaults inline; copy to `.env` only if you want to override them.

# --- PostgreSQL ---
POSTGRES_USER=secondplate
POSTGRES_PASSWORD=secondplate
POSTGRES_DB=secondplate

# --- API ---
# Inside compose the API reaches Postgres at host `db`:
DATABASE_URL=postgresql+psycopg2://secondplate:secondplate@db:5432/secondplate
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
ENVIRONMENT=production

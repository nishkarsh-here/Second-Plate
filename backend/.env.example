# ====================================================================
# SecondPlate backend configuration
# Copy to `.env` and adjust. All settings are read via pydantic-settings.
# ====================================================================

# --- Application ---
APP_NAME=SecondPlate
ENVIRONMENT=development          # development | production
API_PREFIX=/api
LOG_LEVEL=info

# --- Database ---
# Production / Docker / Render -> PostgreSQL (the locked target):
#   postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
# Local zero-setup dev (no Postgres needed) -> SQLite:
#   sqlite:///./local.db
DATABASE_URL=postgresql+psycopg2://secondplate:secondplate@db:5432/secondplate

# --- CORS (comma-separated origins the frontend is served from) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173
# Optional regex to allow dynamic origins, e.g. Vercel preview/prod domains:
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# --- ML ---
# Where the trained surplus model + metadata are serialized.
MODEL_DIR=app/ml/artifacts

# --- Seed behaviour ---
SEED_ON_STARTUP=false            # docker entrypoint handles seeding explicitly
SEED_RANDOM_STATE=42
